# ───────────────────────────────────────────────────────────────
# 猫咪手账 配置示例
# 复制此文件为 .env.local 后按需填写。不填 Supabase 也能用（本地模式）。
# ───────────────────────────────────────────────────────────────

# 站点信息（可选）
VITE_SITE_TITLE=猫咪手账
VITE_SITE_SUBTITLE=记录每一个软乎乎的瞬间
VITE_CAT_NAME=我的小猫

# 访客答题门（JSON 数组）。answers 里任一答对即可，忽略大小写和空格。
# 例：两道题 -> [{"q":"猫咪叫什么？","answers":["咪咪","mimi"]},{"q":"它几岁？","answers":["3","三"]}]
VITE_GATE_QA=[{"q":"请输入暗号才能进入猫咪手账 🐾（提示：猫咪最爱说的话）","answers":["喵","miao","meow"]}]

# 本地模式管理员密码（仅本机有效；云端模式请用下面的 Supabase 账号）
VITE_ADMIN_PASSWORD=meow-admin

# ── 云端模式（填了下面两个就自动切换为多端同步）──
# 在 Supabase 项目 Settings → API 里复制
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# VITE_SUPABASE_BUCKET=cat-photos
